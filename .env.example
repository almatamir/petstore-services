# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# API Ninjas key — used by pet-store to fetch animal taxonomy
# Get one at: https://api-ninjas.com
NINJA_API_KEY=your_api_ninjas_key_here

# Secret for the /transactions owner endpoint in pet-order
OWNER_SECRET=your_owner_secret_here
